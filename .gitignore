# ============================================================
# .gitignore — JWST Deep Field Image Project
# ============================================================
# Raw science data, calibration files, and large outputs
# should NOT be committed to version control.
# Use DVC, Zenodo, or MAST archive links instead.

# ──────────────────────────────────────────
# RAW SCIENCE DATA (MAST / STScI downloads)
# ──────────────────────────────────────────
raw/
data/raw/
*.fits
*.fit
*.fts
*.fits.gz
*.asdf
*_uncal.fits
*_rate.fits
*_rateints.fits

# ──────────────────────────────────────────
# PIPELINE STAGE OUTPUTS (jwst pipeline)
# ──────────────────────────────────────────
# Stage 1 — Detector-level corrections
*_trapsfilled.fits
*_dark.fits
*_jump.fits

# Stage 2 — Instrument-mode corrections
*_cal.fits
*_calints.fits
*_i2d.fits
*_s2d.fits
*_x1d.fits
*_s3d.fits

# Stage 3 — Ensemble / mosaic products
*_crf.fits
*_drizzle.fits
*_mosaic.fits
mosaics/
stage1/
stage2/
stage3/

# ──────────────────────────────────────────
# PROCESSED & SCIENCE-READY IMAGES
# ──────────────────────────────────────────
# Large processed TIFFs / PNGs for publication
processed/
*_final.tiff
*_hires.tiff
*_rgb.tiff
*_color_composite.png
*_release.png
exports/

# ──────────────────────────────────────────
# PHOTOMETRY & CATALOG FILES
# ──────────────────────────────────────────
catalogs/
*.cat
*.reg
*_phot.ecsv
*_sources.fits
*_segmap.fits
*_hotpix.fits

# ──────────────────────────────────────────
# CALIBRATION & REFERENCE FILES (CRDS)
# ──────────────────────────────────────────
crds_cache/
references/
*.rmap
*_flat.fits
*_bias.fits
*_linearity.fits
*_saturation.fits
*_superbias.fits
*_gain.fits
*_readnoise.fits
*_distortion.fits
*_filteroffset.fits
*_photom.fits
*_apcorr.fits

# ──────────────────────────────────────────
# ASTROMETRY & WCS
# ──────────────────────────────────────────
astrometry/
*.wcs
*_wcs.fits
astrometry_net_cache/
.astrometry/

# ──────────────────────────────────────────
# NOTEBOOKS & ANALYSIS CACHE
# ──────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints
__pycache__/
*.py[cod]
.mypy_cache/
.pytest_cache/

# ──────────────────────────────────────────
# ENVIRONMENT & SECRETS
# ──────────────────────────────────────────
.env
.env.*
!.env.example
mast_token.txt
*.apikey

# Python environments
.venv/
venv/
env/
.tox/

# ──────────────────────────────────────────
# LOGS & PIPELINE REPORTS
# ──────────────────────────────────────────
logs/
*.log
jwst_pipeline*.log
asn_*.json
*_manifest.txt

# ──────────────────────────────────────────
# EDITORS & OS
# ──────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# ──────────────────────────────────────────
# WHAT TO KEEP (force-include)
# ──────────────────────────────────────────
# !data/raw/README.md          # Archive download instructions
# !references/crds_context.txt # CRDS context used for reduction
# !notebooks/reduction.ipynb   # Pipeline walkthrough notebook
# !config/jwst_pipeline.cfg    # Custom pipeline config

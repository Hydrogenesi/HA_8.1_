"""
Lineage Logic - Computational Implementation
Hydrogenesis Cosmological Operator

This module implements the Lineage Logic operator,
modeling cosmic continuity and evolutionary recursion.
"""

from dataclasses import dataclass, field
from typing import List, Dict, Optional
from datetime import datetime


@dataclass
class Structure:
    """Generic cosmic structure."""
    structure_id: str
    mass: float
    generation: int
    parent_id: Optional[str] = None
    children: List[str] = field(default_factory=list)
    residue_markers: List[str] = field(default_factory=list)
    
    def replicate(self, num_descendants: int = 2) -> List['Structure']:
        """Generate descendant structures."""
        descendants = []
        mass_per_child = self.mass / num_descendants
        
        for i in range(num_descendants):
            child_id = f"{self.structure_id}-D{i+1}"
            child = Structure(
                structure_id=child_id,
                mass=mass_per_child * (0.9 + 0.2 * (i / num_descendants)),  # Slight variation
                generation=self.generation + 1,
                parent_id=self.structure_id
            )
            descendants.append(child)
            self.children.append(child_id)
        
        return descendants


@dataclass
class ResidueMarker:
    """Memory marker from collapsed lineage."""
    collapsed_id: str
    collapse_time: str
    mass_memory: float
    parent_lineage: str


class LineageLogic:
    """
    Universal recursion engine for cosmic structure continuity.
    
    Tracks lineage trees, manages replication, and preserves
    collapse history through residue markers.
    """
    
    def __init__(self, root_structure: Structure):
        """
        Initialize lineage system with root structure.
        
        Args:
            root_structure: Origin point of lineage tree
        """
        self.root = root_structure
        self.lineage_tree: Dict[str, Structure] = {root_structure.structure_id: root_structure}
        self.history_trace: List[ResidueMarker] = []
        self.active_lineages: List[str] = [root_structure.structure_id]
        self.collapsed_lineages: List[str] = []
        
        print(f"[ROOT] Lineage system initialized: {root_structure.structure_id}")
        print(f"       Root mass: {root_structure.mass:.2e} M☉")
    
    def recurse(self, structure_id: str, num_descendants: int = 2) -> List[Structure]:
        """
        SPLIT phase: Generate descendant structures through replication.
        
        Args:
            structure_id: ID of structure to replicate
            num_descendants: Number of descendants to generate
            
        Returns:
            List of newly created descendant structures
        """
        if structure_id not in self.lineage_tree:
            raise ValueError(f"Structure {structure_id} not found in lineage tree")
        
        parent = self.lineage_tree[structure_id]
        
        print(f"\n[SPLIT] Replicating {structure_id}")
        print(f"        Parent mass: {parent.mass:.2e} M☉")
        print(f"        Generating {num_descendants} descendants")
        
        descendants = parent.replicate(num_descendants)
        
        for desc in descendants:
            self.lineage_tree[desc.structure_id] = desc
            self.active_lineages.append(desc.structure_id)
            print(f"        • Created {desc.structure_id} (M={desc.mass:.2e} M☉)")
        
        return descendants
    
    def preserve(self, structure_id: str, collapse_reason: str = "natural_evolution") -> ResidueMarker:
        """
        TRACE phase: Record collapse event in history thread.
        
        Args:
            structure_id: ID of collapsing structure
            collapse_reason: Reason for collapse
            
        Returns:
            ResidueMarker encoding collapse memory
        """
        if structure_id not in self.lineage_tree:
            raise ValueError(f"Structure {structure_id} not found")
        
        structure = self.lineage_tree[structure_id]
        
        print(f"\n[TRACE] Recording collapse: {structure_id}")
        print(f"        Reason: {collapse_reason}")
        print(f"        Mass memory: {structure.mass:.2e} M☉")
        
        residue = ResidueMarker(
            collapsed_id=structure_id,
            collapse_time=datetime.now().isoformat(),
            mass_memory=structure.mass,
            parent_lineage=structure.parent_id or "ROOT"
        )
        
        self.history_trace.append(residue)
        self.collapsed_lineages.append(structure_id)
        
        if structure_id in self.active_lineages:
            self.active_lineages.remove(structure_id)
        
        # Mark residue in parent if exists
        if structure.parent_id and structure.parent_id in self.lineage_tree:
            parent = self.lineage_tree[structure.parent_id]
            parent.residue_markers.append(structure_id)
        
        print(f"        Residue marker create*
